{
  "project": {
    "name": "PRUEBASCLAUDE",
    "version": "1.0.0",
    "description": "Sistema de tickets interactivo con DJANGO REST APIs"
  },

  "model": "claude-3-5-sonnet-latest",
  
  "context": {
    "include_paths": [
      "manage.py",
      "project/",
      "apps/",
      "templates/",
      "static/"
    ],
    "exclude_paths": [
      "venv/",
      ".venv/",
      "__pycache__/",
      "migrations/",
      "staticfiles/",
      "media/"
    ],
    "max_context_files": 25
  },

  "rules": {
    "coding_style": "django-best-practice",
    "language": "es",
    "response_format": "conciso",
    "prefer_comments": true,
    "prefer_class_based_views": true,
    "avoid_business_logic_in_views": true
  },

  "tools": {
    "enable_web": false,
    "enable_filesystem": true,
    "enable_shell": true
  },
  
  "memory": {
    "enabled": true,
    "persist_session": true,
    "remember": [
      "project_structure",
      "django_apps",
      "database_models"
    ]
  },

  "logging": {
    "level": "info",
    "save_logs": true,
    "log_path": ".claude/logs"
  }
}